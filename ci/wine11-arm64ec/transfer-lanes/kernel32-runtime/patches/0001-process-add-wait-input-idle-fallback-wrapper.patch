diff --git a/dlls/kernel32/process.c b/dlls/kernel32/process.c
--- a/dlls/kernel32/process.c
+++ b/dlls/kernel32/process.c
@@ -63,6 +63,26 @@
 static DWORD (WINAPI *wait_input_idle)( HANDLE process, DWORD timeout );
 
 /***********************************************************************
+ *           call_wait_input_idle
+ *
+ * Prefer the registered callback (legacy contract with user32), but
+ * fall back to resolving WaitForInputIdle directly when it is absent.
+ */
+typedef DWORD (WINAPI *WaitForInputIdle_ptr)( HANDLE hProcess, DWORD dwTimeOut );
+
+static DWORD call_wait_input_idle( HANDLE process, DWORD timeout )
+{
+    HMODULE mod = GetModuleHandleA( "user32.dll" );
+    if (wait_input_idle) return wait_input_idle( process, timeout );
+    if (mod)
+    {
+        WaitForInputIdle_ptr ptr = (WaitForInputIdle_ptr)GetProcAddress( mod, "WaitForInputIdle" );
+        if (ptr) return ptr( process, timeout );
+    }
+    return 0;
+}
+
+/***********************************************************************
  *           RegisterWaitForInputIdle   (KERNEL32.@)
  */
 void WINAPI RegisterWaitForInputIdle( void *ptr )
@@ -93,7 +113,8 @@
                         0, NULL, NULL, &startup, &info ))
     {
         /* Give 30 seconds to the app to come up */
-        if (wait_input_idle) wait_input_idle( info.hProcess, 30000 );
+        if (call_wait_input_idle( info.hProcess, 30000 ) == WAIT_FAILED)
+            WARN("WaitForInputIdle failed: Error %lu\n", GetLastError() );
         ret = 33;
         /* Close off the handles */
         CloseHandle( info.hThread );
@@ -150,7 +171,8 @@
                         params->lpEnvAddress, NULL, &startup, &info ))
     {
         /* Give 30 seconds to the app to come up */
-        if (wait_input_idle) wait_input_idle( info.hProcess, 30000 );
+        if (call_wait_input_idle( info.hProcess, 30000 ) == WAIT_FAILED)
+            WARN("WaitForInputIdle failed: Error %lu\n", GetLastError() );
         ret = 33;
         /* Close off the handles */
         CloseHandle( info.hThread );
