-
-            ctx->progress = true;
-        }
-
-        if (can_propagate_ssa_source(program, ins))
-            state.ssa_sources[ins->dst[0].reg.idx[0].offset] = ins;
-    }
-
-    vkd3d_free(state.ssa_sources);
-    return VKD3D_OK;
-}
