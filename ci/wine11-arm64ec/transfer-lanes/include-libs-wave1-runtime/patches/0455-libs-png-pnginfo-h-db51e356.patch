-   png_uint_16 mastering_blue_x;
-   png_uint_16 mastering_blue_y;
-   png_uint_16 mastering_white_x;
-   png_uint_16 mastering_white_y;
-   png_uint_32 mastering_maxDL; /* cd/m2 (nits) * 10,000 */
-   png_uint_32 mastering_minDL;
-#endif
