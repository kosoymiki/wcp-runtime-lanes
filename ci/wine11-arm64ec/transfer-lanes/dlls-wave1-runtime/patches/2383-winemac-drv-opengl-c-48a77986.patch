+    TRACE("src %p dst %p mask %x\n", src, dst, mask);
+
+    err = CGLCopyContext(src->cglcontext, dst->cglcontext, mask);
+    if (err != kCGLNoError)
+        WARN("CGLCopyContext() failed with err %d %s\n", err, CGLErrorString(err));
+    return (err == kCGLNoError);
+}
