+    .gc_traverse = Enumerator_gc_traverse,
+    .cc_traverse = Enumerator_cc_traverse
 };
 
 static HRESULT alloc_enumerator(script_ctx_t *ctx, jsdisp_t *object_prototype, EnumeratorInstance **ret)
