+static inline void convert_display_rect(CGRect* out_rect, NSRect in_rect,
+                                        NSRect primary_frame)
+{
+    *out_rect = NSRectToCGRect(in_rect);
+    out_rect->origin.y = NSMaxY(primary_frame) - NSMaxY(in_rect);
+}
