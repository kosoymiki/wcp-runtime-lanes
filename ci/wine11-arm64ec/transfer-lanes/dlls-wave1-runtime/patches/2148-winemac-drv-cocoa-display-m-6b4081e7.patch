-
-    /* color characteristics: sRGB */
-    edid[25] = 0xee;
-    edid[26] = 0x91;
-    edid[27] = 0xa3;
-    edid[28] = 0x54;
-    edid[29] = 0x4c;
-    edid[30] = 0x99;
