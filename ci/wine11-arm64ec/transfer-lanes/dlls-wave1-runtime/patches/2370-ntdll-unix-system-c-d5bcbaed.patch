+    tzi->Bias = tz_data.bias;
+    tzi->StandardBias = tz_data.std_bias;
+    tzi->DaylightBias = tz_data.dlt_bias;
+    tzi->StandardDate = tz_data.std_date;
+    tzi->DaylightDate = tz_data.dlt_date;
+
+    ret = TRUE;
+
+done:
+    NtClose( subkey );
+    return ret;
+}
