+static LONG64 get_current_tz_bias(void)
+{
+    ULONG high, low;
+
+    do
+    {
+        high = user_shared_data->TimeZoneBias.High1Time;
+        low = user_shared_data->TimeZoneBias.LowPart;
+    }
+    while (high != user_shared_data->TimeZoneBias.High2Time);
+
+    return ((LONG64)high << 32) | low;
+}
