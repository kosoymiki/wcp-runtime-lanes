+static void fixup_winver(DWORD *verval)
+{
+    static int cached = -1;
+
+    if (cached == -1)
+    {
+        const char *s;
+
+        cached = (s = getenv("STEAM_COMPAT_APP_ID")) &&
+                    (
+                        !strcmp(s, "976730")
+                        || !strcmp(s, "231430")
+                        || !strcmp(s, "1017900")
+                        || !strcmp(s, "285190")
+                        || !strcmp(s, "627270")
+                    );
+        if (cached)
+            ERR("HACK: setting winver 502.\n");
+    }
+    if (!cached) return;
+    if (*verval > 502) *verval = 502;
+}
