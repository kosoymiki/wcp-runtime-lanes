+    /* import RSA key */
+    if ((status = key_export_rsa_public( key, NULL, 0, &len )))
+    {
+        ERR( "Key export failed.\n" );
+        return status;
+    }
+    rsa_blob = malloc( len );
+    if ((status = key_export_rsa_public( key, (UCHAR *)rsa_blob, len, &len )))
+    {
+        ERR( "Key export failed.\n" );
+        return status;
+    }
+    err = pgcry_sexp_build(&sexp_pubkey, NULL,
+                        "(public-key(rsa (e %b)(n %b)))",
