-static BOOL UPDOWN_NeedBuddyBackground(const UPDOWN_INFO *infoPtr)
-{
-#if __WINE_COMCTL32_VERSION == 6
-    HTHEME theme = GetWindowTheme(infoPtr->Self);
-
-    if (theme)
