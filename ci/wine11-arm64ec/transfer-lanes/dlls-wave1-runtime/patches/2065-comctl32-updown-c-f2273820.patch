-static void UPDOWN_DrawUpArrow(const UPDOWN_INFO *infoPtr, HDC hdc)
-{
-    RECT rect;
-#if __WINE_COMCTL32_VERSION == 6
-    HTHEME theme = GetWindowTheme(infoPtr->Self);
-
-    if (theme)
-    {
-        int part = 0, state = 0;
