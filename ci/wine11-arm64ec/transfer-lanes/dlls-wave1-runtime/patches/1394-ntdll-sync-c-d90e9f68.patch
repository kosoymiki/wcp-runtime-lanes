+        ULONG_PTR val = (ULONG_PTR)once->Ptr;
 
         if (flags & RTL_RUN_ONCE_ASYNC) return STATUS_INVALID_PARAMETER;
         if ((val & 3) != 2) return STATUS_UNSUCCESSFUL;
@@ -71,7 +71,7 @@
 
     for (;;)
     {
