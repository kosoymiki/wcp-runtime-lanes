diff --git a/dlls/ntdll/sync.c b/dlls/ntdll/sync.c
--- a/dlls/ntdll/sync.c
+++ b/dlls/ntdll/sync.c
@@ -61,7 +61,7 @@
 {
     if (flags & RTL_RUN_ONCE_CHECK_ONLY)
     {
