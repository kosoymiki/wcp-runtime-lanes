+        ULONG_PTR next, val = (ULONG_PTR)once->Ptr;
 
         switch (val & 3)
         {
@@ -116,7 +116,7 @@
 
     for (;;)
     {
-        ULONG_PTR val = (ULONG_PTR)ReadPointerAcquire( &once->Ptr );
+        ULONG_PTR val = (ULONG_PTR)once->Ptr;
 
         switch (val & 3)
         {
@@ -931,8 +931,8 @@
 {
     struct futex_queue *queue = get_futex_queue( addr );
